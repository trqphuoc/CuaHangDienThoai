<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Cửa hàng điện thoại</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-light mb-3">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="SanPham" asp-action="Index">Cửa hàng</a>
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="SanPham" asp-action="Index">Sản phẩm</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="DonHang" asp-action="LichSu">Đơn hàng</a>
                </li>
            </ul>

            <ul class="navbar-nav ms-auto">
                <li class="nav-item dropdown" style="position: relative;">
                    @if (Context.Session.GetString("TenNguoiDung") != null)
                    {
                        <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            Xin chào, @Context.Session.GetString("TenNguoiDung")
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                            <li><h6 class="dropdown-header">Thông tin tài khoản</h6></li>
                            <li><span class="dropdown-item-text">
                                Họ tên: @Context.Session.GetString("TenNguoiDung")<br />
                                Tên đăng nhập: @Context.Session.GetString("TenDangNhap")
                            </span></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item" asp-controller="NguoiDung" asp-action="ChinhSua">Chi tiết</a></li>
                            <li><a class="dropdown-item" asp-controller="NguoiDung" asp-action="DangXuat">Đăng xuất</a></li>
                        </ul>
                    }
                    else
                    {
                        <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            Người dùng
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                            <li><a class="dropdown-item" asp-controller="NguoiDung" asp-action="DangNhap">Đăng nhập</a></li>
                        </ul>
                    }
                </li>
            </ul>
        </div>
    </nav>

    <div class="container">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        /* Cho dropdown hiện khi hover chuột */
        .nav-item.dropdown:hover > .dropdown-menu {
            display: block;
        }
    </style>
</body>
</html>