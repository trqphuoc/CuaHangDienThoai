@{
    ViewData["Title"] = "Xác nhận mua hàng";
    var sp = ViewBag.SanPham as CuaHangDienThoai.Models.SanPham;
}

<h2>Mua sản phẩm</h2>

@if (ViewBag.ThongBao != null)
{
    <div class="alert alert-danger">@ViewBag.ThongBao</div>
}

<form method="post">
    <input type="hidden" name="id_san_pham" value="@sp.Id_SanPham" />

    <div class="form-group">
        <label>Tên sản phẩm:</label>
        <p><strong>@sp.Ten_SanPham</strong></p>
    </div>

    <div class="form-group">
        <label>Giá:</label>
        <p><strong>@sp.Gia.ToString("N0") VND</strong></p>
    </div>

    <div class="form-group">
        <label>Số lượng:</label>
        <input type="number" name="so_luong" class="form-control" min="1" max="@sp.So_Luong" required />
    </div>

    <div class="form-group">
        <label>Địa chỉ giao hàng:</label>
        <input type="text" name="dia_chi" class="form-control" required />
    </div>

    <button type="submit" class="btn btn-primary mt-2">Đặt hàng</button>
</form>
